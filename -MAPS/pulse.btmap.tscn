[sub_resource type="GDScript" id="GDScript_jwjdk"]
script/source = "extends Area3D

@onready var i1: CSGBox3D = $\"../interactives/1\"
@onready var i2: CSGBox3D = $\"../interactives/2\"

func _ready() -> void:
	global.restart.connect(restart)

func restart() -> void:
	i1.use_collision = true
	i1.show()
	i2.use_collision = true
	i2.show()

func _on_area_entered(_area: Area3D) -> void:
	i1.use_collision = false
	i1.hide()
	i2.use_collision = false
	i2.hide()
"

